{
  "comments": {
    "lineComment": "::"
  },
  "brackets": [
    ["[", "]"],
    ["(", ")"],
    ["{", "}"]
  ],
  "autoClosingPairs": [
    { "open": "[", "close": "]" },
    { "open": "(", "close": ")" },
    { "open": "{", "close": "}" },
    { "open": "\"", "close": "\"", "notIn": ["string", "comment"] },
    { "open": "'", "close": "'", "notIn": ["string", "comment"] },
    { "open": "'''", "close": "'''" },
    { "open": "\"\"\"", "close": "\"\"\"" }
  ],
  "surroundingPairs": [
    ["[", "]"],
    ["(", ")"],
    ["{", "}"],
    ["\"", "\""],
    ["'", "'"]
  ],
  "indentationRules": {
    "increaseIndentPattern": "^((?!::).)*[\\[\\(\\{][^\\]\\)\\}]*$",
    "decreaseIndentPattern": "^\\s*[\\]\\)\\}]"
  },
  "wordPattern": "[a-z][a-z0-9-]*|[A-Z][A-Za-z0-9]*|0x[0-9a-fA-F\\.]+|0b[01\\.]+|@[a-z]*"
}
